# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/nova_reklama_erp

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string_in_production
JWT_EXPIRES_IN=7d

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# CORS — frontend origin
CORS_ORIGIN=http://localhost:3000
